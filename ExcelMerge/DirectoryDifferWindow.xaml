<Window x:Class="ExcelMerge.DirectoryDifferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelMerge"
        mc:Ignorable="d"
        Title="JustDiff - Directory" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#F0F0F0" Padding="8"/>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="8">
            <StackPanel Orientation="Horizontal">
                <Label Name="SrcDir" Foreground="#1E1E2E">c:/dir/to/</Label>
            </StackPanel>
            <DockPanel Margin="0,4,0,0">
                <Label Content="{DynamicResource CommitID}" Foreground="#1E1E2E"/>
                <TextBox Name="FilterCommits" Height="24" HorizontalAlignment="Stretch" />
            </DockPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Button x:Name="DoVersionDiff" Margin="4" Click="DoVersionDiff_Click" Content="{DynamicResource VersionSearch}" Width="70" Height="26"/>
                <Label x:Name="TextTip" Foreground="#1E1E2E"/>
            </StackPanel>
        </StackPanel>

        <local:DirectoryGridControl x:Name="SrcDataGrid" Grid.Column="0" Grid.Row="1" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="src">
        </local:DirectoryGridControl>

        <local:DirectoryGridControl x:Name="DstDataGrid" Grid.Column="1" Grid.Row="1" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="dst">
        </local:DirectoryGridControl>
    </Grid>
</Window>
