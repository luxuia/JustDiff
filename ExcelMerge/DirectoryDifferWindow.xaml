<Window x:Class="ExcelMerge.DirectoryDifferWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ExcelMerge"
        mc:Ignorable="d"
        Title="JustDiff - Directory" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#F0F0F0" Padding="8"/>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="8" Orientation="Horizontal" VerticalAlignment="Center">
            <Label Name="SrcDir" Foreground="#9E9E9E" FontSize="11"
                   ToolTip="{Binding Content, RelativeSource={RelativeSource Self}}"
                   Content="(directory)"/>
        </StackPanel>

        <local:DirectoryGridControl x:Name="SrcDataGrid" Grid.Column="0" Grid.Row="1" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="src">
        </local:DirectoryGridControl>

        <local:DirectoryGridControl x:Name="DstDataGrid" Grid.Column="1" Grid.Row="1" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="dst">
        </local:DirectoryGridControl>

        <!-- No changes overlay -->
        <Border x:Name="NoChangesOverlay" Grid.Row="1" Grid.ColumnSpan="2" Visibility="Collapsed"
                Background="#F8F8F8" IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x2714;" FontSize="48" Foreground="#4CAF50"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="No Changes" FontSize="20" Foreground="#757575"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="All files are identical" FontSize="12"
                           Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
