<Window x:Class="ExcelMerge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:local="clr-namespace:ExcelMerge"
        mc:Ignorable="d"
        Title="JustDiff - Excel" Height="600" Width="1200"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#F0F0F0" Padding="8"/>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="8">
            <StackPanel Orientation="Horizontal">
                <Label Name="SrcFilePath" Foreground="#1E1E2E">c:/dir/to/path.xls</Label>
                <ComboBox Name="SrcFileSheetsCombo" Width="80" IsReadOnly="True" DisplayMemberPath="Name" SelectedValuePath="ID" SelectionChanged="SrcFileSheetsCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Label Content="{DynamicResource ReversionId}" Foreground="#1E1E2E"/>
                <TextBox Name="SVNVerson" Width="60" Height="24" HorizontalContentAlignment="Right"/>
                <Button Name="SVNVersionBtn" Width="50" Content="{DynamicResource ReversionIdConfirm}" Height="26" Margin="6,0" Click="SVNVersionBtn_Click"></Button>
                <Label Content="{DynamicResource ReversionSelect}" Foreground="#1E1E2E"/>
                <ComboBox Name="SVNRevisionCombo" Width="100" DisplayMemberPath="Revision" SelectedValuePath="ID" SelectionChanged="SVNResivionionList_SelectionChanged"/>
                <Label Content="{DynamicResource SortKey}" Foreground="#1E1E2E"/>
                <ComboBox Name="SortKeyCombo" Width="100" DisplayMemberPath="ColumnName" SelectedValuePath="ID" SelectionChanged="SortKeyCombo_SelectionChanged"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="0" Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <Label Name="DstFilePath" Foreground="#1E1E2E">c:/dir/to/path.xls</Label>
                <ComboBox Name="DstFileSheetsCombo" IsReadOnly="True" DisplayMemberPath="Name" Width="80" SelectedValuePath="ID" SelectionChanged="DstFileSheetsCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,4,0,0">
                <Button Name="DoDiff" Margin="4" Click="DoDiff_Click" Content="{DynamicResource DiffLabel}" Width="50" Height="26"/>
                <CheckBox Name="ProcessHeader" Margin="10,6,10,6" Width="69" Click="SimpleHeader_Checked" Content="{DynamicResource SimpleHeaderLabel}" IsChecked="True" />
            </StackPanel>
        </Grid>

        <ProgressBar x:Name="DiffProgressBar" Grid.Row="1" Grid.ColumnSpan="2" Height="4"
                     Minimum="0" Maximum="100" Visibility="Collapsed" Foreground="#0078D7"/>

        <local:ExcelGridControl x:Name="SrcDataGrid" Grid.Column="0" Grid.Row="2" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="src">
        </local:ExcelGridControl>

        <local:ExcelGridControl x:Name="DstDataGrid" Grid.Column="1" Grid.Row="2" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="dst">
        </local:ExcelGridControl>

        <GridSplitter Grid.Row="2" Grid.Column="0" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5"/>
    </Grid>
</Window>
