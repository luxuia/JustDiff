<Window x:Class="ExcelMerge.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/expression/2010/interactivity"
        xmlns:local="clr-namespace:ExcelMerge"
        mc:Ignorable="d"
        Title="JustDiff - Excel" Height="600" Width="1200"
        Closing="Window_Closing">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#F0F0F0" Padding="8"/>

        <StackPanel Grid.Row="0" Grid.Column="0" Margin="8">
            <StackPanel Orientation="Horizontal">
                <Label Name="SrcFilePath" Foreground="#9E9E9E" FontSize="11"
                       ToolTip="{Binding Content, RelativeSource={RelativeSource Self}}"
                       Content="(src)"/>
                <ComboBox Name="SrcFileSheetsCombo" MinWidth="150" IsReadOnly="True" DisplayMemberPath="Name" SelectedValuePath="ID" SelectionChanged="SrcFileSheetsCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                <Label Content="{DynamicResource SortKey}" Foreground="#1E1E2E" VerticalAlignment="Center" Padding="4,0"/>
                <ComboBox Name="SortKeyCombo" Width="100" VerticalAlignment="Center" DisplayMemberPath="ColumnName" SelectedValuePath="ID" SelectionChanged="SortKeyCombo_SelectionChanged"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="0" Grid.Column="1" Margin="8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Orientation="Horizontal" Grid.Row="0">
                <Label Name="DstFilePath" Foreground="#9E9E9E" FontSize="11"
                       ToolTip="{Binding Content, RelativeSource={RelativeSource Self}}"
                       Content="(dst)"/>
                <ComboBox Name="DstFileSheetsCombo" IsReadOnly="True" DisplayMemberPath="Name" MinWidth="150" SelectedValuePath="ID" SelectionChanged="DstFileSheetsCombo_SelectionChanged"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,4,0,0">
                <Button Name="DoDiff" Margin="4,0" Click="DoDiff_Click" Content="{DynamicResource DiffLabel}" Padding="8,2" VerticalAlignment="Center"/>
                <CheckBox Name="ProcessHeader" Margin="10,0" VerticalAlignment="Center" Click="SimpleHeader_Checked" Content="{DynamicResource SimpleHeaderLabel}" IsChecked="True" />
            </StackPanel>
        </Grid>

        <ProgressBar x:Name="DiffProgressBar" Grid.Row="1" Grid.ColumnSpan="2" Height="4"
                     Minimum="0" Maximum="100" Visibility="Collapsed" Foreground="#0078D7"/>

        <local:ExcelGridControl x:Name="SrcDataGrid" Grid.Column="0" Grid.Row="2" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="src">
        </local:ExcelGridControl>

        <local:ExcelGridControl x:Name="DstDataGrid" Grid.Column="1" Grid.Row="2" Margin="1,0,1,1"
            AllowDrop="True"
            Tag="dst">
        </local:ExcelGridControl>

        <GridSplitter Grid.Row="2" Grid.Column="0" Background="Transparent" HorizontalAlignment="Right" VerticalAlignment="Stretch" Width="5"/>

        <!-- No changes overlay -->
        <Border x:Name="NoChangesOverlay" Grid.Row="2" Grid.ColumnSpan="2" Visibility="Collapsed"
                Background="#F8F8F8" IsHitTestVisible="False">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#x2714;" FontSize="48" Foreground="#4CAF50"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="No Changes" FontSize="20" Foreground="#757575"
                           HorizontalAlignment="Center" Margin="0,8,0,0"/>
                <TextBlock Text="The two sheets are identical" FontSize="12"
                           Foreground="#9E9E9E" HorizontalAlignment="Center" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
